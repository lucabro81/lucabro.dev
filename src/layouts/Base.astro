---
import "../styles/global.css";
import IconGithub from "../components/IconGithub.astro";
import IconLinkedin from "../components/IconLinkedin.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Luca Bro — writing on software, design, and craft." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem("theme") ?? "light";
      if (theme === "dark") document.documentElement.classList.add("dark");
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="site">
      <header class="site-header">
        <a href="/" class="site-name">lucabro.dev</a>
        <nav class="site-nav">
          <a href="/now">now</a>
          <a href="/projects">projects</a>
          <a href="/about">about</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" aria-pressed="false">
            <span class="theme-icon">◑</span>
          </button>
        </nav>
      </header>
      <main class="site-main" id="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer-left">
          <span>Luca Brognara</span>
          <a href="https://github.com/lucabro81" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <IconGithub />
          </a>
          <a href="https://www.linkedin.com/in/lucabrognara/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <IconLinkedin />
          </a>
        </div>
        <a href="https://github.com/lucabro81/lucabro.dev" target="_blank" rel="noopener noreferrer" class="site-footer-source">Source</a>
      </footer>
    </div>
    <script is:inline>
      const btn = document.getElementById("theme-toggle");
      const isDarkOnLoad = document.documentElement.classList.contains("dark");
      btn.setAttribute("aria-pressed", isDarkOnLoad ? "true" : "false");
      btn.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        btn.setAttribute("aria-pressed", isDark ? "true" : "false");
      });
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    background: var(--color-bg);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-4);
    border: var(--border-width) solid var(--color-accent);
    border-radius: var(--radius-sm);
    z-index: 100;
  }
  .skip-link:focus-visible {
    top: var(--space-4);
  }

  .site {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  @media (min-width: 1900px) {
    .site {
      max-width: 1600px;
    }
  }

  .site-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: var(--space-8) 0 var(--space-12);
  }

  .site-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    color: var(--color-accent);
    text-decoration: none;
  }
  .site-name:hover {
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .site-nav a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .site-nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1;
    display: flex;
    align-items: center;
  }
  .theme-toggle:hover {
    color: var(--color-text);
  }

  .site-main {
    flex: 1;
  }

  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-12) 0 var(--space-8);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .site-footer-left {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .site-footer-left a {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
  }
  .site-footer-left a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .site-footer-left :global(svg) {
    width: 18px;
    height: 18px;
  }

  .site-footer-source {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .site-footer-source:hover {
    color: var(--color-text);
    text-decoration: none;
  }
</style>
